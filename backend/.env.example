SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key

# เพดานการเรียก Gemini "ต่อโมเดล" ต่อนาที (ค่าเริ่มต้น 4 — เผื่อ buffer จากลิมิต free tier 5)
# ถ้าเปิด billing แล้ว ปรับขึ้นได้ เช่น 60
GEMINI_MAX_RPM=

# ลำดับโมเดลที่ใช้ (คั่นด้วย comma) — โควต้า free tier นับแยกต่อโมเดล
# ตัวแรกเต็มจะไหลไปตัวถัดไปอัตโนมัติ ค่าเริ่มต้น: gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_MODELS=

# (ออปชัน) Groq เป็น OCR backend เพิ่ม — โควต้า free tier สูงกว่า Gemini และนับแยกต่อคีย์
# ใส่ได้หลายคีย์ คั่นด้วย comma เพื่อรวมโควต้า เช่น gsk_xxx,gsk_yyy
GROQ_API_KEYS=
# โมเดล Groq ที่รองรับ vision (ค่าเริ่มต้น: meta-llama/llama-4-scout-17b-16e-instruct)
GROQ_MODELS=
# เพดานเรียก Groq ต่อคีย์ต่อนาที (ค่าเริ่มต้น 25)
GROQ_MAX_RPM=

# (บังคับ) Channel ID ของ LINE Login channel ที่ผูกกับ LIFF = ส่วนหน้าของ LIFF ID
# backend ใช้ตรวจว่า access token ออกให้ channel นี้จริง — production ไม่ยอมบูตถ้าไม่ตั้ง (boot guard ใน app.js)
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id

# จำกัด CORS เฉพาะโดเมน frontend (คั่นหลายค่าด้วย comma) เว้นว่าง = ปิดกั้นทุก origin (fail-closed)
# เช่น https://your-app.vercel.app หรือ pattern แบบ https://frontend-*.vercel.app
CORS_ORIGIN=

PORT=3000

# (เฉพาะ dev) ตั้ง = true เพื่อข้ามการยืนยัน LINE token แล้วใช้ผู้ใช้จำลอง — ทดสอบครบวงในเครื่อง
# ได้โดยไม่ต้อง deploy (userId ตรงกับ LIFF mock ฝั่ง frontend) ⚠️ ห้ามตั้งบน production
DEV_FAKE_LINE_USER=

# ─────────────────── (ออปชัน) OCR benchmark — bench/ ───────────────────
# ใส่เฉพาะค่ายที่อยากเทสเทียบ (harness ข้ามค่ายที่ไม่มี key ให้อัตโนมัติ) — ดู bench/README.md
# Gemini/Groq ใช้คีย์ด้านบนอยู่แล้ว ไม่ต้องซ้ำ
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
MISTRAL_API_KEY=
OCR_SPACE_API_KEY=
GOOGLE_VISION_API_KEY=
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
# GitHub Models (ฟรีสำหรับ dev) — PAT ที่มี permission "Models: Read" (ghp_... หรือ github_pat_...)
GITHUB_TOKEN=
# Hugging Face (hf_...) — token ต้องเปิดสิทธิ์ "Make calls to Inference Providers"
HF_TOKEN=
# Zhipu (智谱/GLM) — คีย์รูปแบบ id.secret; vision: glm-5v-turbo(default) · glm-4.6v · glm-4v-flash(ฟรี)
# ค่ายนี้เป็น reasoning model → harness ปิด thinking ให้แล้ว (เร็ว 83s→11s). base ปรับได้ถ้าใช้บัญชี z.ai สากล
ZHIPU_API_KEY=
ZHIPU_MODEL=
ZHIPU_BASE_URL=
# (ออปชัน) override โมเดลต่อค่าย เช่น OPENROUTER_MODEL, CLOUDFLARE_MODEL, NVIDIA_MODEL, MISTRAL_MODEL, ZHIPU_MODEL,
# GITHUB_MODEL (เช่น openai/gpt-4o-mini, microsoft/Phi-4-multimodal-instruct), HF_MODEL (ดู router /v1/models),
# BENCH_GEMINI_MODEL, BENCH_GROQ_MODEL
